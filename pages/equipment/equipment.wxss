/* 装备推荐页面样式 */

/* 场景选择 */
.scene-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.scene-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: var(--bg-tertiary);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.scene-item.active {
  background-color: rgba(88, 166, 255, 0.15);
  border-color: var(--accent-blue);
}

.scene-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.scene-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.scene-item.active .scene-name {
  color: var(--accent-blue);
}

/* 目标鱼种 */
.fish-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.fish-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background-color: var(--bg-tertiary);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.fish-item.active {
  background-color: rgba(35, 134, 54, 0.15);
  border-color: var(--accent-green);
}

.fish-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.fish-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.fish-item.active .fish-name {
  color: var(--accent-green);
}

/* 装备推荐 */
.equipment-section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.section-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.equipment-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.equipment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: var(--bg-tertiary);
  border-radius: 12rpx;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.item-spec {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.item-price {
  font-size: 28rpx;
  color: var(--accent-yellow);
  font-weight: 600;
}

/* 技巧提示 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx;
  background-color: var(--bg-tertiary);
  border-radius: 12rpx;
}

.tip-number {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: var(--accent-blue);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.5;
}
